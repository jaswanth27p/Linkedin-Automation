{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*", "tests/**/*", "linkedin-auto.config.ts"]
}
