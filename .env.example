OPENCODE_API_KEY=
REDIS_URL=redis://localhost:6380
DATABASE_URL=postgres://app:app@localhost:5433/linkedin_auto
# Set to true to show the raw agent tool-call trace in the TUI log panel (dev only).
# Off by default — normal users see just the natural-language agent flow.
# The full trace always goes to data/app.log regardless of this setting.
DEV_LOGS=false
# Reused for every external-site account-creation signup (see external-apply-agent).
# WARNING: this value flows into the agent's prompt text the same way resume.md/
# profile.json content does, and per the existing logging design it will be written
# to data/app.log in plaintext whenever the external-apply agent runs. Treat that
# log file as sensitive if you set this.
SITE_ACCOUNT_PASSWORD=
# Port for the local review dashboard (Bun.serve(), same process as the TUI).
DASHBOARD_PORT=4870
